# Facebook Graph API
FB_PAGE_ID=your_page_id_here
FB_ACCESS_TOKEN=your_long_lived_page_access_token_here
FB_AD_ACCOUNT_ID=act_your_ad_account_id_here

# Instagram Graph API (uses same FB_ACCESS_TOKEN — System User token)
IG_USER_ID=your_ig_business_account_id_here

# OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Product Info (used if config.json not present)
PRODUCT_NAME=My Product
PRODUCT_DESCRIPTION=A great product that solves problems
PRODUCT_PRICE=99.00
PRODUCT_URL=https://example.com/product

# Scheduling (cron syntax)
POST_SCHEDULE=0 8,18 * * *
COMMENT_POLL_INTERVAL_MINUTES=15

# Ads
DAILY_AD_BUDGET_USD=5.00
AD_SPEND_ALERT_THRESHOLD_USD=10.00
AD_CTR_DROP_ALERT_THRESHOLD=0.01

# Web UI
PORT=3000
